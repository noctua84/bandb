  password:
  host: 127.0.0.1
  pool: 5

test:
  url: {{envOr "TEST_DATABASE_URL" "postgres://<user>:<password>@127.0.0.1:5432/bandb_test?sslmode=disable"}}

production:
  url: {{envOr "DATABASE_URL" "postgres://<user>:<password>@127.0.0.1:5432/bandb_production?sslmode=disable"}}
